{
  "name": "dotenv-run",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel --no-cache --filter='./packages/*'",
    "test": "turbo test --filter='./packages/*'",
    "build": "turbo build  --filter='./packages/*'",
    "build:docs": "turbo build  --filter='./docs'",
    "prepare": "husky install"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.3",
    "concurrently": "^8.2.2",
    "husky": "^8.0.0",
    "turbo": "^1.12.4",
    "typescript": "^5.4.0",
    "vitest": "^0.33.0"
  },
  "workspaces": {
    "packages": [
      "examples",
      "packages/*",
      "docs"
    ]
  },
  "packageManager": "pnpm@9.1.3+sha512.7c2ea089e1a6af306409c4fc8c4f0897bdac32b772016196c469d9428f1fe2d5a21daf8ad6512762654ac645b5d9136bb210ec9a00afa8dbc4677843ba362ecd"
}
